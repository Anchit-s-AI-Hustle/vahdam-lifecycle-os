# ════════════════════════════════════════════════════════════════════════════
# VAHDAM Mailer Studio — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# Copy to `.env.local` for local `vercel dev` use, OR add in Vercel dashboard
# under Settings → Environment Variables for Production / Preview / Development.
#
# NEVER commit a populated `.env.local` — it's already in `.gitignore`.
# This `.env.example` IS committed (no real values, just placeholders).
#
# PROVIDER CASCADE: OpenAI → Anthropic (Claude) → Gemini → Grok/xAI
# The pipeline tries providers in this order. Configure as many as you have.
# ════════════════════════════════════════════════════════════════════════════

# ─── TIER 1: OpenAI / ChatGPT (primary — paid) ────────────────────────────
# Get key:  https://platform.openai.com/api-keys
# Fund:     https://platform.openai.com/settings/organization/billing ($5 min)
# Rotate if quota hits → add OPENAI_API_KEY_2 and OPENAI_API_KEY_3 as backups
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# ─── TIER 2: Anthropic / Claude (fallback — paid) ─────────────────────────
# Get key:  https://console.anthropic.com/settings/keys
# Used:     when OpenAI is quota-exhausted or rate-limited
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-3-5-haiku-20241022

# ─── TIER 3: Google Gemini (fallback — FREE tier available) ───────────────
# Get key:  https://aistudio.google.com/app/apikey (free, sign in with Google)
# Free tier: 1,500 requests/day · 1M tokens/day on gemini-2.0-flash
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ─── TIER 4: Grok / xAI (final fallback) ─────────────────────────────────
# Get key:  https://console.x.ai
XAI_API_KEY=
GROK_TEXT_MODEL=grok-3-mini-fast

# ─── OPTIONAL — Supabase (cross-device dashboard storage) ─────────────────
# If unset, dashboard falls back to localStorage-only.
# Get from: https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── Google Sheets auth — TWO modes (pick ONE) ───────────────────────────
#
# MODE A (PREFERRED — keyless, can't be "rotated to death"):
# Workload Identity Federation. Vercel mints a short-lived OIDC token per
# request; Google STS swaps it for a federated access token; we impersonate
# the SA via IAM Credentials. No key file anywhere. Full setup in
# docs/workload-identity-federation.md.
#
# Required:
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/123456789012/locations/global/workloadIdentityPools/vercel-pool/providers/vercel-provider
GCP_SERVICE_ACCOUNT_EMAIL=lifecycle-os-bot@vahdam-lifecycle-os.iam.gserviceaccount.com
# Also REQUIRED: enable "OIDC Tokens" in Vercel Project Settings → Environment
# Variables → OIDC Tokens. That injects VERCEL_OIDC_TOKEN automatically — do
# NOT set it manually here.

# MODE B (LEGACY — JSON key in env, what we used before WIF):
# Use only if WIF isn't set up yet. The code prefers Mode A when GCP_*
# vars are present, so it's safe to leave both populated during cutover.
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL=hub-bot@vahdam-lifecycle-os.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Sheet target (used by BOTH modes)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Emails

# ─── INTERNAL — set by Vercel automatically; do NOT override ──────────────
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=...
# VERCEL_OIDC_TOKEN=...   (injected per-request when OIDC Tokens is enabled)
