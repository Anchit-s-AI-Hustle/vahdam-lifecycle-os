# ============================================================================
#  Competitor Intelligence Hub — Environment Variables
#  Copy this file to `.env.local` for local dev. In production, add each of
#  these in the Vercel dashboard (Project → Settings → Environment Variables).
#  NEVER commit real values.
# ============================================================================

# --- Gmail IMAP (the inbox being monitored) --------------------------------
# The full email address of the monitored inbox.
GMAIL_IMAP_USER=ojhapraneet@gmail.com
# A Gmail *App Password* (16 chars, NOT the normal account password).
# Generate at: https://myaccount.google.com/apppasswords  (2FA must be ON).
GMAIL_IMAP_PASSWORD=your-16-char-app-password
# IMAP host/port — defaults are correct for Gmail; only change for other providers.
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# --- Google Service Account (Sheets + Drive access) ------------------------
# The service account's email, e.g. hub-bot@my-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# The service account's private key. Paste the FULL key including the
# -----BEGIN PRIVATE KEY----- / -----END PRIVATE KEY----- lines.
# In Vercel, paste it with literal newlines OR with \n escapes — the code
# normalizes both. If your shell mangles newlines, wrap the whole value in
# double quotes and use \n between lines.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Google Sheet (the database) -------------------------------------------
# The long ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-google-sheet-id
# Tab/sheet name to write to (must match the tab at the bottom of the sheet).
GOOGLE_SHEET_TAB=Emails

# --- Google Drive root folder ----------------------------------------------
# Optional: pre-created Drive folder ID to use as "Competitor_Benchmarking_Hub".
# If omitted, the app creates/finds a folder by name on first run.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Screenshot rendering service ------------------------------------------
# Provider: "hcti" (htmlcsstoimage.com) or "urlbox".
SCREENSHOT_PROVIDER=hcti
# HCTI uses a user id + api key pair. Get them at https://htmlcsstoimage.com/
HCTI_USER_ID=your-hcti-user-id
HCTI_API_KEY=your-hcti-api-key
# URLBox alternative (only needed if SCREENSHOT_PROVIDER=urlbox)
URLBOX_API_KEY=your-urlbox-api-key
URLBOX_API_SECRET=your-urlbox-secret

# --- Cron / route protection -----------------------------------------------
# A random secret. Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# --- Gmail OAuth2 (for users.watch() + Pub/Sub Push real-time sync) --------
# Create an OAuth 2.0 Client ID in GCP (APIs & Services → Credentials).
# Application type: "Web application". Authorized redirect URI:
#   http://localhost:8765/cb  (used by scripts/gmail-oauth-bootstrap.mjs)
GMAIL_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-client-secret
# Mint with: node scripts/gmail-oauth-bootstrap.mjs (one-time, locally).
GMAIL_OAUTH_REFRESH_TOKEN=your-refresh-token

# --- Pub/Sub topic + push subscription (real-time) -------------------------
# Full topic name (created via `gcloud pubsub topics create gmail-push-competitors`).
GMAIL_PUBSUB_TOPIC=projects/vahdam-lifecycle-os/topics/gmail-push-competitors
# Audience claim in the Pub/Sub Push JWT. Set this to the EXACT URL of the
# webhook (this app's /api/gmail-push). It is also what you pass as
# `--push-auth-token-audience` when creating the subscription.
GMAIL_PUBSUB_AUDIENCE=https://your-app.vercel.app/api/gmail-push
# Service account that Pub/Sub uses to sign the push JWT. Set when creating
# the subscription with --push-auth-service-account=<this email>.
GMAIL_PUBSUB_SA_EMAIL=pubsub-push@vahdam-lifecycle-os.iam.gserviceaccount.com
